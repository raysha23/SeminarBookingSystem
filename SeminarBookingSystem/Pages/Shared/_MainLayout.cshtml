@* File Path: SeminarBookingSystem/Pages/Shared/_MainLayout.cshtml *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Seminar Booking System</title>
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Font Awesome (icons only) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

</head>

<body>
    <!-- HEADER -->
    <div class="header">
        <div class="header-left">
            <h3>Seminar Booking System</h3>
            <span>Admin Portal</span>
        </div>

        <div class="admin-profile">
            <div class="admin-info">
                <strong>Super Admin</strong>
                <span>Administrator</span>
            </div>

            <a href="/Logout" class="logout-btn">
                <i class="fa-solid fa-right-from-bracket"></i> Logout
            </a>
        </div>
    </div>
    <!-- MAIN CONTENT -->
    <div class="main-content">
        <!-- SIDEBAR -->
        <div class="sidebar">
            <ul class="nav">
                <li class="nav-item">
                    <a href="/Dashboard" class="nav-link active">
                        <i class="fa-solid fa-table-cells-large"></i> Dashboard
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Seminars" class="nav-link">
                        <i class="fa-regular fa-calendar-days"></i> Seminars
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Participants" class="nav-link">
                        <i class="fa-solid fa-users"></i> Participants
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Bookings" class="nav-link">
                        <i class="fa-solid fa-clock-rotate-left"></i> Booking History
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/Logs" class="nav-link">
                        <i class="fa-solid fa-wave-square"></i> Activity Logs
                    </a>
                </li>

                <li class="nav-item">
                    <a href="/UserManagement" class="nav-link">
                        <i class="fa-solid fa-user-gear"></i> User Management
                    </a>
                </li>
            </ul>
        </div>

        <!-- CONTENT -->
        <div class="content">
            @RenderBody()
        </div>
    </div>

</body>

</html>