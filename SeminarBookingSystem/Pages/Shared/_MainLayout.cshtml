@* File Path: SeminarBookingSystem/Pages/Shared/_MainLayout.cshtml *@
@using Microsoft.AspNetCore.Identity
@using SeminarBookingSystem.Models
@inject SignInManager<AdminUser> SignInManager
@inject UserManager<AdminUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - Seminar Booking System</title>
	<link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>

<body>
	<!-- HEADER -->
	<div class="header">
		<div class="header-left">
			<h3>Seminar Booking System</h3>
			<span>Admin Portal</span>
		</div>

		<div class="admin-profile">
			<div class="admin-info">
				@* Display current logged-in user's name *@
				@if (SignInManager.IsSignedIn(User))
				{
					var currentUser = await UserManager.GetUserAsync(User);
					<strong>@currentUser.FullName</strong>
					<span>Administrator</span>
				}
			</div>

			<form method="post" asp-area="Identity" asp-page="/Account/Logout" style="display:inline;">
				@Html.AntiForgeryToken()
				<button type="submit" class="logout-btn">
					<i class="fa-solid fa-right-from-bracket"></i> Logout
				</button>
			</form>
		</div>
	</div>

	<!-- MAIN CONTENT -->
	<div class="main-content">
		@{
			var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
		}
		<!-- SIDEBAR -->
		<div class="sidebar">
			<ul class="nav">
				<li class="nav-item">
					<a href="/Dashboard" class="nav-link @(currentPage == "/Dashboard" ? "active" : "")">
						<i class="fa-solid fa-table-cells-large"></i> Dashboard
					</a>
				</li>

				<li class="nav-item">
					<a href="/Seminars/Index" class="nav-link @(currentPage == "/Seminars/Index" ? "active" : "")">
						<i class="fa-regular fa-calendar-days"></i> Seminars
					</a>
				</li>

				<li class="nav-item">
					<a href="/Participants/Index"
					   class="nav-link @(currentPage == "/Participants/Index" ? "active" : "")">
						<i class="fa-solid fa-users"></i> Participants
					</a>
				</li>

				<li class="nav-item">
					<a href="/BookingHistory" class="nav-link @(currentPage == "/BookingHistory" ? "active" : "")">
						<i class="fa-solid fa-clock-rotate-left"></i> Booking History
					</a>
				</li>

				<li class="nav-item">
					<a href="/ActivityLogs" class="nav-link @(currentPage == "/ActivityLogs" ? "active" : "")">
						<i class="fa-solid fa-wave-square"></i> Activity Logs
					</a>
				</li>

				@* Only show User Management link if the user is Super Admin *@
				@if (SignInManager.IsSignedIn(User))
				{
					var currentUser = await UserManager.GetUserAsync(User);
					var roles = await UserManager.GetRolesAsync(currentUser);
					if (roles.Contains("Super Admin"))
					{
						<a href="/UserManagements/UserManagement" class="nav-link @(currentPage == "/UserManagements/UserManagement" ? "active" : "")">
							<i class="fa-solid fa-user-gear"></i> User Management
						</a>
					}
				}
			</ul>
		</div>

		<!-- CONTENT -->
		<div class="content">
			@RenderBody()
		</div>
	</div>

	@* Toast messages *@
	@{
		var successMessage = TempData["SuccessMessage"] as string;
		var errorMessage = TempData["ErrorMessage"] as string;
	}

	@if (!string.IsNullOrEmpty(successMessage))
	{
		<div id="successToast" class="toast toast-success">
			<i class="bi bi-check-circle-fill"></i> @successMessage
		</div>
	}

	@if (!string.IsNullOrEmpty(errorMessage))
	{
		<div id="errorToast" class="toast toast-error">
			<i class="bi bi-exclamation-circle-fill"></i> @errorMessage
		</div>
	}

	<script>
		window.onload = function () {
			document.querySelectorAll('.toast').forEach(toast => {
				setTimeout(() => {
					toast.style.opacity = '0';
					toast.style.transform = 'translateY(-20px)';
					setTimeout(() => toast.remove(), 500);
				}, 3000);
			});
		};
	</script>
</body>
</html>