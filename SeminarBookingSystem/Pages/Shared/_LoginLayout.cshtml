<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Seminar Booking System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
                            * {
                                box-sizing: border-box;
                            }

                            body {
                                margin: 0;
                                height: 100vh;
                                background-color: #eef4ff;
                                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;

                                display: flex;
                                align-items: center;
                                justify-content: center;
                            }

                            .container {
                                width: 100%;
                                max-width: 420px;
                                padding: 16px;
                                text-align: center;
                            }

                            .brand-icon {
                                width: 60px;
                                height: 60px;
                                background: #0d6efd;
                                color: white;
                                border-radius: 50%;
                                margin: 0 auto 20px;

                                display: flex;
                                align-items: center;
                                justify-content: center;

                                font-size: 24px;
                            }

                            .title {
                                font-size: 22px;
                                font-weight: bold;
                                margin-bottom: 4px;
                            }

                            .subtitle {
                                color: #6c757d;
                                margin-bottom: 20px;
                            }

                            .login-card {
                                background: white;
                                border-radius: 12px;
                                padding: 24px;
                                text-align: left;

                                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
                            }

                            .card-title {
                                font-weight: bold;
                                margin-bottom: 4px;
                            }

                            .card-subtitle {
                                color: #6c757d;
                                font-size: 14px;
                                margin-bottom: 16px;
                            }

                            .form-group {
                                margin-bottom: 16px;
                            }

                            .form-label {
                                display: block;
                                font-size: 13px;
                                font-weight: 600;
                                margin-bottom: 4px;
                                color: #555;
                            }

                            .form-input {
                                width: 100%;
                                padding: 10px;
                                border-radius: 8px;
                                border: none;
                                background-color: #f4f6f9;
                                font-size: 14px;
                            }

                            .form-input:focus {
                                outline: 2px solid #0d6efd;
                            }

                            .btn-login {
                                width: 100%;
                                padding: 12px;
                                background: #05070a;
                                color: white;
                                border: none;
                                border-radius: 8px;
                                font-weight: bold;
                                cursor: pointer;
                                font-size: 14px;
                                text-align: center;
                            }
                            .btn-login i {
                                margin-right: 11px;
                                font-size: 16px;
                            }

                            .btn-login:hover {
                                opacity: 0.9;
                            }

                            .demo-box {
                                margin-top: 20px;
                                background: #f0f7ff;
                                padding: 12px;
                                border-radius: 8px;
                            }

                            .demo-title {
                                color: #0d6efd;
                                font-weight: bold;
                                font-size: 13px;
                                margin-bottom: 6px;
                            }

                            .demo-text {
                                color: #0d6efd;
                                font-size: 13px;
                                margin: 0;
                            }

                            .footer-text {
                                margin-top: 20px;
                                font-size: 13px;
                                color: #6c757d;
                            }
    </style>
</head>

<body>
    <div class="container">
        @RenderBody()
    </div>
</body>

</html>