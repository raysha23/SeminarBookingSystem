@page
@model SeminarBookingSystem.Pages.ActivityLogsModel
@{
    Layout = "_MainLayout";
}

<link rel="stylesheet" href="~/css/activitylogs.css" />

<div class="activity-page">
    <div class="header-section">
        <h1>Activity Logs</h1>
        <p class="subtitle">Track all admin actions and system changes</p>
    </div>

    <div class="filter-card">
        <div class="search-wrapper">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search logs..." id="searchLogs">
        </div>
        <select class="log-dropdown" id="actionFilter">
            <option value="">All Actions</option>
            <option value="created">Created</option>
            <option value="updated">Updated</option>
            <option value="deleted">Deleted</option>
            <option value="restored">Restored</option>

        </select>
        <select class="log-dropdown" id="entityFilter">
            <option value="">All Entities</option>
            <option value="seminar">Seminar</option>
            <option value="user">User</option>
        </select>
    </div>

    <div class="main-log-card">
        <div class="card-header">
            <h3>Activity Log</h3>
            <span>@Model.Logs.Count log entries found</span>
        </div>

        @if (!Model.Logs.Any())
        {
            <div class="empty-state-container">
                <div class="empty-state-content">
                    <i class="bi bi-activity"></i>
                    <p>No activity logs found</p>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="log-table">
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Entity</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.Logs)
                        {
                            <tr>
                                <td>
                                    <div class="timestamp-cell">
                                        <i class="bi bi-calendar3"></i>
                                        <div>
                                            <div class="date">@log.Timestamp.ToString("MMM dd, yyyy")</div>
                                            <div class="time">@log.Timestamp.ToString("HH:mm:ss")</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="user-name">@log.UserId</div>
                                    <div class="sub-text">ID: @log.UserId</div>
                                </td>
                                <td>
                                    <span class="badge-action @log.Action.ToLower()">
                                        @log.Action.ToLower()
                                    </span>
                                </td>
                                <td>
                                    <span class="badge-entity @log.Entity.ToLower()">
                                        @log.Entity.ToLower()
                                    </span>
                                </td>
                                <td>
                                    <div class="detail-main">@log.Details</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-number">@Model.TotalActivities</div>
            <div class="stat-label">Total Activities</div>
        </div>
        <div class="stat-card">
            <div class="stat-number green">@Model.CreatedCount</div>
            <div class="stat-label">Created</div>
        </div>
        <div class="stat-card">
            <div class="stat-number blue">@Model.UpdatedCount</div>
            <div class="stat-label">Updated</div>
        </div>
        <div class="stat-card">
            <div class="stat-number red">@Model.DeletedCount</div>
            <div class="stat-label">Deleted</div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const searchInput = document.getElementById("searchLogs");
        const actionFilter = document.getElementById("actionFilter");
        const entityFilter = document.getElementById("entityFilter");

        function normalize(text) {
            return text ? text.toString().toLowerCase().trim() : "";
        }

        function filterLogs() {
            const rows = document.querySelectorAll(".log-table tbody tr");

            const searchText = normalize(searchInput.value);
            const actionValue = normalize(actionFilter.value);
            const entityValue = normalize(entityFilter.value);

            let visibleCount = 0;

            rows.forEach(row => {

                // ❗ Ignore "No results row"
                if (row.id === "noResultsRow") return;

                const user = normalize(row.querySelector(".user-name")?.textContent);
                const action = normalize(row.querySelector(".badge-action")?.textContent);
                const entity = normalize(row.querySelector(".badge-entity")?.textContent);
                const details = normalize(row.querySelector(".detail-main")?.textContent);

                // ✅ SEARCH (now includes everything)
                const matchSearch =
                    !searchText ||
                    user.includes(searchText) ||
                    details.includes(searchText) ||
                    action.includes(searchText) ||
                    entity.includes(searchText);

                // ✅ FILTERS (fixed comparison)
                const matchAction =
                    !actionValue || action.includes(actionValue);

                const matchEntity =
                    !entityValue || entity.includes(entityValue);

                if (matchSearch && matchAction && matchEntity) {
                    row.style.display = "";
                    visibleCount++;
                } else {
                    row.style.display = "none";
                }
            });

            toggleNoResults(visibleCount === 0);
        }

        function toggleNoResults(show) {
            let noResultRow = document.getElementById("noResultsRow");
            const tbody = document.querySelector(".log-table tbody");

            if (!tbody) return;

            if (show) {
                if (!noResultRow) {
                    noResultRow = document.createElement("tr");
                    noResultRow.id = "noResultsRow";
                    noResultRow.innerHTML = `
                        <td colspan="5" style="text-align:center; padding:20px; color:#94a3b8;">
                            No matching logs found
                        </td>
                    `;
                    tbody.appendChild(noResultRow);
                }
            } else {
                if (noResultRow) {
                    noResultRow.remove();
                }
            }
        }

        // ✅ Attach events safely
        if (searchInput) searchInput.addEventListener("input", filterLogs);
        if (actionFilter) actionFilter.addEventListener("change", filterLogs);
        if (entityFilter) entityFilter.addEventListener("change", filterLogs);

    });
</script>