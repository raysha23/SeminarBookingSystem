@page
@model SeminarBookingSystem.Pages.DashboardModel
@{
    Layout = "_MainLayout";
    ViewData["Title"] = "Dashboard";
}
<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="whole-container">
    <header class="dashboard-header">
        <h1>Dashboard</h1>
        <p>Welcome back, Super Admin</p>
    </header>

    <div class="cards-container">
        <div class="card">
            <div class="card-text">
                <h3>Total Seminars</h3>
                <span class="stat-number">@Model.TotalSeminars</span>
                <p class="stat-detail">@Model.UpcomingSeminars.Count upcoming</p>
            </div>
            <div class="card-icon blue"><i class="bi bi-calendar"></i></div>
        </div>

        <div class="card">
            <div class="card-text">
                <h3>Activities</h3>
                <span class="stat-number">@Model.TotalActivities</span>
                <p class="stat-detail">Total admin actions</p>
            </div>
            <div class="card-icon orange"><i class="bi bi-activity"></i></div>
        </div>
    </div>

    <div class="bottom-grid">
        <section class="content-section">
            <div class="section-header">
                <h2>Upcoming Seminars</h2>
                <p>Next scheduled events</p>
            </div>
            <div class="scrollable-content">
                <div class="seminar-list">
                    @if (!Model.UpcomingSeminars.Any())
                    {
                        <p>No upcoming seminars</p>
                    }
                    else
                    {
                        @foreach (var seminar in Model.UpcomingSeminars)
                        {
                            <div class="seminar-item">
                                <div class="seminar-info">
                                    <h4>@seminar.SeminarTitle</h4>
                                    <p class="location">@seminar.Location</p>
                                    <p class="date">@seminar.Date.ToString("MMM dd, yyyy")</p>
                                </div>
                                <div class="seminar-meta">
                                    <span class="badge">@seminar.Status</span>
                                    <p class="booked">@seminar.CurrentParticipants/@seminar.Capacity booked</p>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </section>

        <section class="content-section">
            <div class="section-header">
                <h2>Recent Activity</h2>
                <p>Latest admin actions</p>
            </div>
            <div class="scrollable-content">
                @if (!Model.RecentActivities.Any())
                {
                    <div class="empty-state">
                        <p>No recent activity</p>
                    </div>
                }
                else
                {
                    <ul class="activity-list">
                        <div class="activity-list">
                            @foreach (var log in Model.RecentActivities)
                            {
                                <div class="activity-item">
                                    <div class="activity-top">
                                        <span class="activity-user">@log.UserId</span>
                                        <span class="activity-time">@log.Timestamp.ToString("MMM dd, HH:mm")</span>
                                    </div>
                                    <p class="activity-details">@log.Details</p>
                                    <div class="activity-badges">
                                        <span class="badge-action @log.Action.ToLower()">@log.Action.ToLower()</span>
                                        <span class="badge-entity @log.Entity.ToLower()">@log.Entity.ToLower()</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </ul>
                }
            </div>
        </section>
    </div>

    <div class="quick-actions-section">
        <div class="section-header">
            <h3>Quick Actions</h3>
            <p>Common tasks</p>
        </div>
        <div class="quick-actions-grid">
            <button class="action-btn" onclick="location.href='@Url.Page("/Seminars/Create")'">
                <i class="fa-regular fa-calendar-plus"></i>
                <span>Create Seminar</span>
            </button>

            <button class="action-btn" onclick="location.href='@Url.Page("ActivityLogs")'">
                <i class="bi bi-activity"></i>
                <span>View Logs</span>
            </button>
        </div>
    </div>
</div>