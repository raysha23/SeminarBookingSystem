@* File Path: SeminarBookingSystem/Pages/UserManagements/UserManagement.cshtml *@
@page "/UserManagement"
@model UserManagementModel
@{
    Layout = "_MainLayout";
    ViewData["Title"] = "User Management";
}
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

<link rel="stylesheet" href="~/css/user-management.css" asp-append-version="true" />

<div class="management-container">
    <header class="page-header">
        <div class="header-text">
            <h1>User Management</h1>
            <p>Manage admin users and permissions</p>
        </div>
        <button class="btn-primary open-modal">+ Add Admin User</button>
    </header>

    <div class="alert-box">
        <i class="bi bi-shield"></i>
        <div class="alert-content">
            <strong>Super Admin Privileges</strong>
            <p>
                Only Super Admins can create, edit, and delete admin users. All new users will have the default password:
                <code class="pwd-highlight">admin123</code>
            </p>
        </div>
    </div>

    <div class="filter-bar">
        <div class="search-wrapper">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" placeholder="Search users...">
        </div>
        <select class="role-select">
            <option>All Roles</option>
            <option>Super Admin</option>
            <option>Staff Admin</option>
        </select>
    </div>

    <div class="table-card">
        <div class="table-header">
            <h3>Admin Users</h3>
            <p>1 user</p>
        </div>
        <table class="user-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Created At</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            @* <tbody>
                <tr>
                    <td>
                        <div class="user-name">
                            <i class="bi bi-shield"></i>
                            Super Admin
                            <span class="badge-you">You</span>
                        </div>
                    </td>
                    <td>admin@seminar.com</td>
                    <td><span class="role-badge">super admin</span></td>
                    <td>Mar 17, 2026</td>
                    <td class="text-right actions">
                        <button class="icon-btn edit"><i class="fa-regular fa-pen-to-square"></i></button>
                        <button class="icon-btn delete"><i class="fa-regular fa-trash-can"></i></button>
                    </td>
                </tr>
            </tbody> *@
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>
                            <div class="user-name">
                                <i class="bi @(Model.UserRoles[user.Id] == "Super Admin" ? "bi-shield" : "bi-person-gear")"></i>
                                @user.FullName
                            </div>
                        </td>
                        <td>@user.Email</td>
                        <td>
                            <span class="role-badge">
                                @Model.UserRoles[user.Id]
                            </span>
                        </td>
                        <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td class="text-right actions">
                            <button class="icon-btn edit"
                                    data-name="@user.FullName"
                                    data-email="@user.Email"
                                    data-role="@Model.UserRoles[user.Id]">
                                <i class="fa-regular fa-pen-to-square"></i>
                            </button>
                            <button class="icon-btn delete" data-id="@user.Id">
                                <i class="fa-regular fa-trash-can"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="summary-grid">
        <div class="summary-card">
            <div class="card-info">
                <p>Super Admins</p>
                <span class="count">1</span>
            </div>
            <i class="bi bi-shield"></i>
        </div>
        <div class="summary-card">
            <div class="card-info">
                <p>Staff Admins</p>
                <span class="count blue">0</span>
            </div>
            <i class="fa-solid fa-users-gear settings-icon"></i>
        </div>
    </div>
</div>
<!-- MODAL -->
<div class="modal" id="adminModal">
    <div class="modal-content">
        <button class="close-btn">&times;</button>
        <h2 class="modal-title">Add Admin User</h2>
        <p class="subtitle">Create a new admin account</p>
        <form method="post" id="adminForm">
            <input type="hidden" asp-for="EditInput.Id" id="editId" />
            <div class="form-group">
                <input type="hidden" asp-for="EditInput.Id" id="editId" />
                <label asp-for="Input.FullName"></label>
                <input asp-for="Input.FullName" class="form-control" placeholder="John Doe" />
                <span asp-validation-for="Input.FullName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" class="form-control" placeholder="john@seminar.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Role"></label>
                <select asp-for="Input.Role" class="form-control">
                    <option value="">-- Select Role --</option>
                    <option value="Staff Admin">Staff Admin</option>
                    <option value="Super Admin">Super Admin</option>
                </select>
                <span asp-validation-for="Input.Role" class="text-danger"></span>
            </div>

            <div class="note-box">
                <strong>Note:</strong> Default password: <strong>Admin123!</strong>
            </div>

            <div class="footer">
                <button type="button" class="btn btn-cancel">Cancel</button>
                <button type="submit" class="btn btn-create">Create User</button>
            </div>
        </form>
    </div>
</div>

<!-- DELETE CONFIRM MODAL -->
<div class="modal" id="deleteModal">
    <div class="modal-content delete-modal-content">
        <h2>Delete User</h2>
        <p>Are you sure you want to delete this admin user? This action will soft delete the user account and prevent them from logging in.</p>
        <div class="modal-footer">
            <button type="button" class="btn btn-cancel-delete">Cancel</button>
            <button type="button" class="btn btn-delete-confirm">Delete</button>
        </div>
    </div>
</div>

<form id="deleteForm" method="post" style="display:none;">
    <input type="hidden" name="id" id="deleteUserId" />
</form>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const modal = document.getElementById("adminModal");
        const form = document.getElementById("adminForm");

        const openBtn = document.querySelector(".open-modal"); // Create button
        const editButtons = document.querySelectorAll(".icon-btn.edit");

        const closeBtn = modal.querySelector(".close-btn");
        const cancelBtn = modal.querySelector(".btn-cancel");

        const inputFullName = document.getElementById("Input_FullName");
        const inputEmail = document.getElementById("Input_Email");
        const inputRole = document.getElementById("Input_Role");
        const inputId = document.getElementById("editId");

        const modalTitle = modal.querySelector(".modal-title");
        const subtitle = modal.querySelector(".subtitle");

        const submitButton = document.querySelector(".btn-create");
        const notebox = document.querySelector(".note-box");

      
        // ✅ CREATE MODE
        openBtn?.addEventListener("click", () => {
            modal.classList.add("show");

            form.action = "?handler=CreateAdmin";

            modalTitle.textContent = "Add Admin User";
            subtitle.textContent = "Create a new admin account";

            inputId.value = "";
            inputFullName.value = "";
            inputEmail.value = "";
            inputRole.value = "Staff Admin";
        });

        // ✅ EDIT MODE
        editButtons.forEach(btn => {
            btn.addEventListener("click", () => {
                modal.classList.add("show");

                form.action = "?handler=Edit";

                modalTitle.textContent = "Edit Admin User";
                subtitle.textContent = "Update user information";
                submitButton.textContent = "Update User";
                notebox.style.display = "none";
                inputId.value = btn.dataset.id;
                inputFullName.value = btn.dataset.name;
                inputEmail.value = btn.dataset.email;
                inputRole.value = btn.dataset.role;
            });
        });

        // Close modal
        const closeModal = () => {
            modal.classList.remove("show");
            form.reset();
        };

        closeBtn.addEventListener("click", closeModal);
        cancelBtn.addEventListener("click", closeModal);

        window.addEventListener("click", e => {
            if (e.target === modal) closeModal();
        });

    });


    const deleteModal = document.getElementById("deleteModal");
    const deleteButtons = document.querySelectorAll(".icon-btn.delete");
    const cancelDeleteBtn = deleteModal.querySelector(".btn-cancel-delete");
    const confirmDeleteBtn = deleteModal.querySelector(".btn-delete-confirm");
    const deleteForm = document.getElementById("deleteForm");
    const deleteUserIdInput = document.getElementById("deleteUserId");

    let selectedUserId = null;

    // When clicking the trash icon
    deleteButtons.forEach(btn => {
        btn.addEventListener("click", () => {
            selectedUserId = btn.dataset.id;
            deleteModal.classList.add("show");
        });
    });

    // Cancel button closes modal
    cancelDeleteBtn.addEventListener("click", () => {
        deleteModal.classList.remove("show");
        selectedUserId = null;
    });

    // Confirm delete
    confirmDeleteBtn.addEventListener("click", () => {
        if (!selectedUserId) return;
        deleteUserIdInput.value = selectedUserId;
        deleteForm.action = "?handler=Delete"; // matches OnPostDeleteAsync
        deleteForm.submit();
    });

    // Close modal by clicking outside
    window.addEventListener("click", e => {
        if (e.target === deleteModal) {
            deleteModal.classList.remove("show");
            selectedUserId = null;
        }
    });
</script>