@page
@model SeminarBookingSystem.Pages.Seminars.CreateModel

@{
    Layout = "_MainLayout";
    ViewData["Title"] = "Create New Seminar";
}
<link rel="stylesheet" href="~/css/seminar-create.css" asp-append-version="true" />

<div class="form-page-container">
    <div class="top-nav">
        <a asp-page="Index" class="back-link">
            <span class="arrow"><i class="bi bi-arrow-left"></i> Back</span>
        </a>
        <div class="header-text">
            <h1>Create New Seminar</h1>
            <p>Add a new seminar event</p>
        </div>
    </div>

    <div class="form-card">
        <div class="form-card-header">
            <h2>Seminar Information</h2>
            <p>Fill in the details for the seminar event</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Seminar.SeminarTitle">Seminar Title <span class="required">*</span></label>
                    <input asp-for="Seminar.SeminarTitle" placeholder="e.g., Digital Marketing Strategies 2026" />
                    <span asp-validation-for="Seminar.SeminarTitle" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Seminar.Description">Description <span class="required">*</span></label>
                    <textarea asp-for="Seminar.Description" rows="3"
                              placeholder="Enter a detailed description of the seminar..."></textarea>
                    <span asp-validation-for="Seminar.Description" class="text-danger"></span>
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Seminar.Date">Date <span class="required">*</span></label>
                    <input asp-for="Seminar.Date" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="Seminar.Date" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Seminar.Time">Time <span class="required">*</span></label>
                    <input asp-for="Seminar.Time" type="time" />
                    <span asp-validation-for="Seminar.Time" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Seminar.Location">Location <span class="required">*</span></label>
                    <input asp-for="Seminar.Location" placeholder="e.g., Grand Conference Hall, Building A" />
                    <span asp-validation-for="Seminar.Location" class="text-danger"></span>
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Seminar.Capacity">Capacity <span class="required">*</span></label>
                    <input asp-for="Seminar.Capacity" type="number" placeholder="50" />
                    <span asp-validation-for="Seminar.Capacity" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save">
                    <span class="save-icon"><i class="bi bi-floppy"></i></span> Create Seminar
                </button>
                <a asp-page="Index" class="btn-cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const seminarForm = document.querySelector("form");
        const titleInput = document.getElementById("Seminar_SeminarTitle");
        const descriptionInput = document.getElementById("Seminar_Description");
        const dateInput = document.getElementById("Seminar_Date");
        const timeInput = document.getElementById("Seminar_Time");
        const locationInput = document.getElementById("Seminar_Location");
        const capacityInput = document.getElementById("Seminar_Capacity");

        // ===== Helper Functions =====
        function showError(input, msg) {
            const span = input.parentElement.querySelector(".text-danger");
            if (span) span.textContent = msg;
        }

        function clearError(input) {
            const span = input.parentElement.querySelector(".text-danger");
            if (span) span.textContent = "";
        }

        function isPositiveInteger(value) {
            return /^\d+$/.test(value) && parseInt(value) > 0;
        }

        // ===== LIVE INPUT RESTRICTION =====
        [titleInput, descriptionInput, locationInput].forEach(input => {
            input.addEventListener("input", function () {
                // Only letters, numbers, spaces, .,!?- allowed
                this.value = this.value.replace(/[^a-zA-Z0-9\s.,!?-]/g, '');
                if (input === titleInput && this.value.length > 50) {
                    this.value = this.value.slice(0, 50); // Max length 50 for title
                }
            });
        });

        capacityInput.addEventListener("input", function () {
            // Only digits allowed
            this.value = this.value.replace(/[^0-9]/g, '');
        });

        // ===== FORM SUBMIT VALIDATION =====
        seminarForm.addEventListener("submit", function (e) {
            let valid = true;

            [titleInput, descriptionInput, dateInput, timeInput, locationInput, capacityInput].forEach(clearError);

            // Title validation
            const titleLen = titleInput.value.trim().length;
            if (!titleInput.value.trim()) {
                showError(titleInput, "Seminar Title is required.");
                valid = false;
            } else if (titleLen < 10 || titleLen > 50) {
                showError(titleInput, "Title must be 10–50 characters.");
                valid = false;
            }

            // Description validation
            if (!descriptionInput.value.trim()) {
                showError(descriptionInput, "Description is required.");
                valid = false;
            }

            // Date validation
            if (!dateInput.value) {
                showError(dateInput, "Date is required.");
                valid = false;
            } else if (new Date(dateInput.value) < new Date(new Date().setHours(0,0,0,0))) {
                showError(dateInput, "Date cannot be in the past.");
                valid = false;
            }

            // Time validation
            if (!timeInput.value) {
                showError(timeInput, "Time is required.");
                valid = false;
            }

            // Location validation
            if (!locationInput.value.trim()) {
                showError(locationInput, "Location is required.");
                valid = false;
            }

            // Capacity validation
            if (!capacityInput.value.trim()) {
                showError(capacityInput, "Capacity is required.");
                valid = false;
            } else if (!isPositiveInteger(capacityInput.value.trim())) {
                showError(capacityInput, "Capacity must be a positive integer.");
                valid = false;
            }

            if (!valid) e.preventDefault(); // Prevent form submission if invalid
        });
    });
</script>