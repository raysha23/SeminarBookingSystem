@page
@model SeminarBookingSystem.Pages.AboutModel
@{
    Layout = "_MainLayout";
}
<link rel="stylesheet" href="~/css/about.css" />

<div class="about-container">
    <section class="about-section">
        <div class="section-badge">System Overview</div>
        <h1>Seminar Booking System</h1>
        <p class="subtitle">An easy way to manage seminars and track participants.</p>

        <div class="content-grid">
            <div class="info-card">
                <h3>What is it?</h3>
                <p>This Seminar Booking System is a web application that helps admins manage seminars. It allows users to create and organize seminar events, monitor system activity, and manage user accounts in one place.</p>
            </div>

            <div class="info-card">
                <h3>The Problem It Solves</h3>
                <p>Managing seminars manually can lead to disorganized records and difficulty tracking activities. This system solves these problems by providing a simple dashboard, organized seminar management, and activity logs to monitor all actions in the system.</p>
            </div>
        </div>
    </section>

    <hr class="section-divider">

    <section class="about-section developer-section">
        <div class="developer-layout">
            <div class="dev-info">
                <div class="section-badge">The Developer</div>
                <h2>Raymund Sismundo</h2>
                <p class="role">Computer Science Student & Aspiring Full-Stack Developer</p>

                <div class="bio">
                    <p>I developed this system to improve my skills in web development and to create a project that solves real-world problems. My goal is to become a full-stack developer, and I enjoy building systems that are simple, clean, and easy to use.</p>
                </div>

                <div class="tech-stack">
                    <h4>Technologies Used:</h4>
                    <div class="tags">
                        <span class="tag">ASP.NET Core Razor Pages</span>
                        <span class="tag">Entity Framework Core</span>
                        <span class="tag">SQL Server</span>
                        <span class="tag">HTML,CSS & Razor</span>
                        <span class="tag">JavaScript</span>
                    </div>
                </div>
            </div>

            <div class="dev-visual">
                <div class="profile-circle">
                    <i class="fa-solid fa-code"></i>
                </div>
            </div>
        </div>
    </section>
</div>