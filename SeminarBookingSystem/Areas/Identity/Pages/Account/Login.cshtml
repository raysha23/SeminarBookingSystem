@* File Path: SeminarBookingSystem/Areas/Identity/Pages/Account/Login.cshtml *@
@page
@model LoginModel
@{
    Layout = "_LoginLayout";
}

<div>
    <div class="brand-icon"><i class="bi bi-calendar-heart-fill"></i></div>

    <div class="title">Seminar Booking System</div>
    <div class="subtitle">Admin Portal</div>

    <div class="login-card">
        <div class="card-title">Sign In</div>
        <div class="card-subtitle">Enter your credentials</div>

        <form method="post">
            <div class="form-group">
                <label class="form-label">Email</label>
                <input type="email" class="form-input" placeholder="admin@seminar.com" required>
            </div>

            <div class="form-group">
                <label class="form-label">Password</label>
                <input type="password" class="form-input" placeholder="Enter your password" required>
            </div>

            <button type="submit" class="btn-login"><i class="bi bi-box-arrow-in-right"></i>Sign In</button>
        </form>

        <div class="demo-box">
            <div class="demo-title">Demo Credentials:</div>
            <p class="demo-text">Email: admin@seminar.com</p>
            <p class="demo-text">Password: admin123</p>
        </div>
    </div>

    <div class="footer-text">
        Contact your Super Admin if you need access
    </div>
</div>