@page
@model ForgotPasswordModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Forgot Password";
}
<link href="~/css/forgot-password.css" rel="stylesheet" />
<div class="container">
    <div class="brand-icon">
        <i class="bi bi-calendar-heart"></i>
    </div>
    <div class="title">Seminar Booking System</div>
    <div class="subtitle">Admin Portal</div>

    <div class="login-card">
        <div class="card-title">Forgot Password</div>
        <div class="card-subtitle">Enter your email to reset your password</div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

            <div class="form-group">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email" class="form-input" placeholder="admin@seminar.com" autocomplete="email" aria-required="true" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-login">
                <i class="bi bi-envelope-paper"></i> Send Reset Link
            </button>
        </form>

        <div class="form-options" style="margin-top: 20px; justify-content: center;">
            <div class="forgot-password">
                <a asp-page="./Login">Back to Sign In</a>
            </div>
        </div>
    </div>

    <div class="footer-text">
        Contact your Super Admin if you need access
    </div>
</div>